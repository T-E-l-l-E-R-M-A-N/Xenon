<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Xenon.Core.ViewModels;assembly=Xenon.Core"
             xmlns:avalonia="https://github.com/projektanker/icons.avalonia"
             xmlns:views="clr-namespace:Xenon.UI.Views"
             xmlns:controls="clr-namespace:Xenon.Controls;assembly=Xenon.Controls"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Xenon.UI.Views.SearchPage"
             x:DataType="viewModels:SearchPageViewModel">
    <DockPanel LastChildFill="True">
       
        <Border Height="50"
                DockPanel.Dock="Top">
            <Border Height="40"
                    VerticalAlignment="Center"
                    Margin="10,0"
                    Background="DimGray">
                <DockPanel LastChildFill="True">
                    <avalonia:Icon DockPanel.Dock="Right"
                                   Margin="10,0"
                                   FontSize="20"
                                   Foreground="White"
                                   Value="mdi magnify"
                                   RenderTransform="scaleX(-1)" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Foreground="White"
                             Background="Transparent">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Return"
                                        Command="{Binding SearchCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                </DockPanel>
            </Border>
        </Border>
        <Grid Background="Black"
              ClipToBounds="True"
              IsVisible="{Binding PlayingTrackTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              DockPanel.Dock="Bottom"
              Height="48">
            <asyncImageLoader:AdvancedImage Source="{Binding PlayingImage}"
                                            Stretch="UniformToFill"
                                            Opacity="0.8"
                                            Margin="-10"
                                            Effect="blur(40)"/>
            <DockPanel LastChildFill="True"
                       VerticalAlignment="Center"
                       Margin="12,0"
                       Height="34">
                <Grid Width="38">
                    <avalonia:Icon FontSize="24"
                                   Foreground="White"
                                   Value="mdi dots-horizontal" />
                </Grid>
                <Button DockPanel.Dock="Right"
                        Command="{Binding TogglePlayCommand}">
                    <Button.Template>
                        <ControlTemplate>
                            <Grid Background="Transparent" Width="38"
                                  Height="38">
                                <avalonia:Icon FontSize="24"
                                               Foreground="White"
                                               Value="mdi play" />
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Grid>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="{Binding PlayingTrackTitle}"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="12,0"
                               Foreground="White" />
                </Grid>
            </DockPanel>
        </Grid>
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Tracks}"
                          Margin="10,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button HorizontalAlignment="Stretch"
                            Command="{Binding $parent[views:SearchPage].((viewModels:SearchPageViewModel)DataContext).PlayCommand}"
                            CommandParameter="{Binding .}">
                            <Button.Template>
                                <ControlTemplate>
                                    <Border MaxWidth="470"
                                            MinWidth="320"
                                            Height="50"
                                            Margin="0,0,0,10"
                                            Background="Transparent">
                                        <DockPanel LastChildFill="True"
                                                   HorizontalSpacing="12">
                                            <Border Width="{Binding $self.Bounds.Height}"
                                                    Background="DimGray">
                                                <Grid>
                                                    <avalonia:Icon FontSize="30"
                                                                   Margin="0,2,0,-2"
                                                                   Foreground="DeepPink"
                                                                   Value="mdi headphones" />
                                                    <asyncImageLoader:AdvancedImage Source="{Binding Image}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock FontSize="14"
                                                       Margin="0,0"
                                                       VerticalAlignment="Center"
                                                       DockPanel.Dock="Right"
                                                       FontFamily="avares://Xenon.Core/Assets#FatGrot"
                                                       Text="{Binding Time, StringFormat=m\\:ss}">
                                            </TextBlock>
                                            <StackPanel VerticalAlignment="Center"
                                                        Spacing="0">
                                                <TextBlock FontSize="18"
                                                           FontFamily="avares://Xenon.Core/Assets#FatGrot"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Name, Converter={StaticResource StringCaseConverter}, ConverterParameter=u}" />
                                                <TextBlock FontSize="14"
                                                           FontWeight="Light"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Artist}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
