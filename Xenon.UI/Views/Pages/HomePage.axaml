                                <avalonia:Icon FontSize="24"
                                               Foreground="White"
                                               Value="mdi play" />
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Grid>
                   
                    <StackPanel Spacing="5"
                                Margin="10,15,0,0"
                                VerticalAlignment="Top">
                        <TextBlock VerticalAlignment="Center"
                                   Text="now playing"
                                   TextTrimming="CharacterEllipsis"
                                   FontWeight="Thin"
                                   Foreground="ForestGreen" />
